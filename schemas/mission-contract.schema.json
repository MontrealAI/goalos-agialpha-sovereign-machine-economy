{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "goalos/mission-contract.schema.json",
  "type": "object",
  "required": [
    "id",
    "version",
    "objective",
    "scenario",
    "success_criteria",
    "constraints",
    "done_condition"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "scenario": {
      "type": "string"
    },
    "success_criteria": {
      "type": "array"
    },
    "constraints": {
      "type": "array"
    },
    "done_condition": {
      "type": "string"
    }
  }
}