{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GoalOS Contradiction Register",
  "type": "object",
  "required": [
    "id",
    "mission_id",
    "contradictions",
    "resolution_status"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "mission_id": {
      "type": "string"
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "resolution_status": {
      "type": "string"
    }
  }
}
